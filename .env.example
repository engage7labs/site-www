# engage7-web — environment configuration example
# Copy this file to .env.local and fill in values for your environment.

# --- Environment ---
# Value: "dev" or "development" for DEV; "prod" or "production" for PROD
# Controls: DEV marker visibility, page title prefix, metadata base URL
NEXT_PUBLIC_APP_ENV=dev

# --- API ---
# Public/browser-visible backend API base URL.
# Local dev: http://127.0.0.1:8000
# Production (Vercel): set to the active Engage7 API runtime URL.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Server-side Engage7 API URL for Next.js route handlers/proxies.
# Required in Vercel Production/Preview and any production-like runtime.
# Local non-hosted development may omit this to use http://127.0.0.1:8000.
ENGAGE7_API_BASE_URL=http://127.0.0.1:8000

# --- Site URL ---
# Public base URL for social sharing, Open Graph metadata, and canonical URLs.
# If not set, defaults to:
#   - DEV (NEXT_PUBLIC_APP_ENV=dev|development): https://dev.engage7.ie
#   - PROD (NEXT_PUBLIC_APP_ENV=prod|production): https://www.engage7.ie
# Vercel preview deployments: typically not required (behavior driven by NEXT_PUBLIC_APP_ENV)
# Local dev: http://localhost:3000 or leave unset if using DEV default
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Cloudflare Turnstile ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# --- Supabase ---
# Hosted DEV must use a separate DEV Supabase project/database/Auth setup.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# --- PostHog Analytics (Sprint 11 / Sprint 41.9) ---
# PostHog project API key — leave empty to disable telemetry in dev
NEXT_PUBLIC_POSTHOG_KEY=
# PostHog reverse-proxy host (Sprint 41.9: https://t.engage7.ie in production)
# Leave as eu.i.posthog.com for local dev without the proxy
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
# PostHog UI host — used for toolbar and user-facing links (default: https://eu.posthog.com)
NEXT_PUBLIC_POSTHOG_UI_HOST=https://eu.posthog.com

# --- Locale ---
# Default locale for the application
NEXT_PUBLIC_DEFAULT_LOCALE=en-IE

# --- Request Signing (Sprint 11.5) — server-only, NOT NEXT_PUBLIC_ ---
# HMAC secret shared with the API. Leave blank to disable (dev).
# Generate with: openssl rand -hex 32
# ENGAGE7_SIGNING_SECRET=
# ENGAGE7_SIGNING_KEY_ID=engage7-web
# --- Auth / JWT (Sprint 17.4+) — server-only ---
# JWT signing secret for session tokens and password reset tokens.
# Generate with: openssl rand -hex 32
# ENGAGE7_JWT_SECRET=
# ENGAGE7_ADMIN_EMAIL=admin@engage7.ie
# ENGAGE7_ADMIN_PASSWORD_HASH=

# --- App URL (used in email links) ---
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Email (Sprint 17.4+) ---
# Resend API key — leave blank to skip email sending in dev.
# RESEND_API_KEY=
# EMAIL_FROM=Engage7 <noreply@engage7.ie>
