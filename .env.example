# engage7-web — environment configuration example
# Copy this file to .env.local and fill in values for your environment.

# --- Environment ---
# dev = local development | prod = production deployment
NEXT_PUBLIC_APP_ENV=dev

# --- API ---
# Backend API base URL
# Local dev: http://localhost:8000
# Production (Vercel): set to https://api.engage7.ie via Vercel dashboard env var
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- Site ---
# Public site URL (used for social share links)
# Production: set to your actual domain (e.g. https://engage7.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Cloudflare Turnstile ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# --- PostHog Analytics (Sprint 11) ---
# PostHog project API key — leave empty to disable telemetry in dev
NEXT_PUBLIC_POSTHOG_KEY=
# PostHog API host (default: https://eu.i.posthog.com)
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# --- Locale ---
# Default locale for the application
NEXT_PUBLIC_DEFAULT_LOCALE=en-IE

# --- Request Signing (Sprint 11.5) — server-only, NOT NEXT_PUBLIC_ ---
# HMAC secret shared with the API. Leave blank to disable (dev).
# Generate with: openssl rand -hex 32
# ENGAGE7_SIGNING_SECRET=
# ENGAGE7_SIGNING_KEY_ID=engage7-web
# Internal API URL for server-side proxy (defaults to NEXT_PUBLIC_API_BASE_URL)
# API_BASE_URL=http://localhost:8000
# --- Auth / JWT (Sprint 17.4+) — server-only ---
# JWT signing secret for session tokens and password reset tokens.
# Generate with: openssl rand -hex 32
# ENGAGE7_JWT_SECRET=
# ENGAGE7_ADMIN_EMAIL=admin@engage7.ie
# ENGAGE7_ADMIN_PASSWORD_HASH=

# --- App URL (used in email links) ---
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Email (Sprint 17.4+) ---
# Resend API key — leave blank to skip email sending in dev.
# RESEND_API_KEY=
# EMAIL_FROM=Engage7 <noreply@engage7.ie>