# engage7-web — safe local development defaults
# Copy this file to .env.local. Do not commit real .env files or secrets.

NEXT_PUBLIC_APP_ENV=dev
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=en-IE

# Optional local integrations. Leave blank unless you are testing them.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_UI_HOST=https://eu.posthog.com
RESEND_API_KEY=
EMAIL_FROM=Engage7 Labs <noreply@engage7.ie>

# Optional local auth/request-signing placeholders.
# ENGAGE7_SIGNING_SECRET=
# ENGAGE7_SIGNING_KEY_ID=engage7-web
# ENGAGE7_JWT_SECRET=
# ENGAGE7_ADMIN_EMAIL=
# ENGAGE7_ADMIN_PASSWORD_HASH=
